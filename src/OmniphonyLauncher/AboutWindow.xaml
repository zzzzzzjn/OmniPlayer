<Window x:Class="OmniphonyLauncher.AboutWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="{DynamicResource AboutTitle}" Width="560" Height="590" ResizeMode="NoResize"
 WindowStyle="None" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False"
 WindowStartupLocation="CenterOwner" Foreground="{StaticResource TextPrimary}" KeyDown="Window_KeyDown">
 <Border Background="#0D0D12" BorderBrush="#353540" BorderThickness="1" CornerRadius="20" Padding="24">
  <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="8" Opacity="0.48"/></Border.Effect>
  <Grid>
   <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="190"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
   <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown">
    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
    <TextBlock Text="{DynamicResource AboutTitle}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
    <Button Grid.Column="1" Content="×" Width="42" Height="42" Padding="0" Margin="0" FontSize="20" Click="Close_Click" AutomationProperties.Name="{DynamicResource Close}"/>
   </Grid>
   <Border Grid.Row="1" Background="#09090D" CornerRadius="14" Margin="0,18,0,18" ClipToBounds="True" AutomationProperties.Name="{DynamicResource AboutProductLogo}">
    <Image Source="assets/omniplayer.png" Width="164" Height="164" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
   </Border>
   <StackPanel Grid.Row="2" HorizontalAlignment="Center">
    <TextBlock Text="OmniPlayer" FontSize="26" FontWeight="SemiBold" HorizontalAlignment="Center"/>
    <TextBlock x:Name="VersionText" Foreground="{StaticResource TextSecondary}" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
   </StackPanel>
   <Grid Grid.Row="3" Margin="12,22,12,0">
    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
    <StackPanel><TextBlock Text="{DynamicResource AboutDevelopersLabel}" Foreground="{StaticResource TextSecondary}" FontSize="11"/><TextBlock Text="{DynamicResource AboutDevelopersValue}" FontSize="13" FontWeight="SemiBold" Margin="0,5,0,0"/></StackPanel>
    <StackPanel Grid.Column="1"><TextBlock Text="{DynamicResource AboutContactLabel}" Foreground="{StaticResource TextSecondary}" FontSize="11"/><TextBlock Text="{DynamicResource AboutContactValue}" FontSize="13" FontWeight="SemiBold" Margin="0,5,0,0"/></StackPanel>
   </Grid>
   <Border Grid.Row="4" Height="1" Background="#2A2A33" Margin="12,20,12,18"/>
   <StackPanel Grid.Row="5" Margin="12,0">
    <TextBlock Text="{DynamicResource AboutCopyrightTitle}" FontSize="13" FontWeight="SemiBold"/>
    <TextBlock Text="{DynamicResource AboutCopyrightBody}" Foreground="#C5C5CC" FontSize="12" TextWrapping="Wrap" Margin="0,7,0,0"/>
    <TextBlock Text="{DynamicResource AboutLegalNote}" Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="0,9,0,0"/>
   </StackPanel>
   <Button Grid.Row="6" Content="{DynamicResource Close}" HorizontalAlignment="Right" MinWidth="92" Margin="0,18,0,0" Click="Close_Click"/>
  </Grid>
 </Border>
</Window>
