<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>OmniPlayer</AssemblyName>
    <RootNamespace>OmniphonyLauncher</RootNamespace>
    <Version>1.3.0</Version>
    <Product>OmniPlayer</Product>
    <AssemblyTitle>OmniPlayer</AssemblyTitle>
    <ApplicationIcon>assets\omniplayer.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup><Resource Include="assets\omniplayer.png" /><Resource Include="assets\omniplayer.ico" /></ItemGroup>
</Project>
