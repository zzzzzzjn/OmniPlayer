<Window x:Class="OmniphonyLauncher.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="OmniPlayer" Icon="assets/omniplayer.png" Width="1120" Height="800" MinWidth="940" MinHeight="680"
 Background="{StaticResource Surface}" Foreground="{StaticResource TextPrimary}" AllowDrop="True" Drop="Window_Drop">
 <Grid>
  <Grid.Background><RadialGradientBrush Center="0.78,0.03" GradientOrigin="0.78,0.03" RadiusX="0.75" RadiusY="0.9"><GradientStop Color="#201035"/><GradientStop Color="#09080E" Offset="0.58"/></RadialGradientBrush></Grid.Background>
  <Grid Margin="26,22,26,18">
   <Grid.RowDefinitions><RowDefinition Height="82"/><RowDefinition Height="*"/><RowDefinition Height="28"/></Grid.RowDefinitions>

   <Grid Grid.Row="0">
    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
    <Border Width="64" Height="64" CornerRadius="14" BorderBrush="#5D4078" BorderThickness="1" Background="#0C0A12" ClipToBounds="True">
     <Image Source="assets/omniplayer.png" Stretch="UniformToFill"/>
    </Border>
    <StackPanel Grid.Column="1" Margin="15,5,0,0">
     <TextBlock FontSize="23" FontWeight="SemiBold"><Run Text="OMNI" Foreground="{StaticResource Cyan}"/><Run Text="PLAYER" Foreground="#C178FF"/></TextBlock>
     <TextBlock Text="I M M E R S I V E   A U D I O   C O N T R O L" FontSize="9" Foreground="#84798F" FontWeight="SemiBold" Margin="2,5,0,0"/>
    </StackPanel>
    <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
     <Border Background="#171121" BorderBrush="#3F2D55" BorderThickness="1" CornerRadius="18" Padding="14,7"><StackPanel Orientation="Horizontal"><Ellipse Width="7" Height="7" Fill="#42E89B" Margin="0,0,8,0"/><TextBlock x:Name="OverallStatus" Text="正在检查核心组件" FontSize="12"/></StackPanel></Border>
     <TextBlock Text="v1.3 · PORTABLE READY" FontSize="9" Foreground="#756A82" HorizontalAlignment="Right" Margin="0,6,4,0"/>
    </StackPanel>
   </Grid>

   <TabControl Grid.Row="1">
    <TabItem Header="播放控制">
     <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,8">
      <Grid>
       <Grid.ColumnDefinitions><ColumnDefinition Width="1.55*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
       <StackPanel Grid.Column="0">
        <Border Style="{StaticResource CardStyle}">
         <StackPanel>
          <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
           <StackPanel><TextBlock Text="当前片源" Style="{StaticResource SectionTitle}"/><TextBlock Text="拖入空间音频文件，或从磁盘中选择" Style="{StaticResource MutedText}" FontSize="11" Margin="4,-4,0,6"/></StackPanel>
           <Border Grid.Column="1" Background="#26183A" CornerRadius="5" Padding="9,4" VerticalAlignment="Top"><TextBlock Text="E-AC-3 · TRUEHD · ATMOS" Foreground="#C99BFF" FontSize="9" FontWeight="SemiBold"/></Border>
          </Grid>
          <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
           <TextBox x:Name="MediaPathBox" ToolTip="也可以将视频文件拖到窗口"/>
           <Button Grid.Column="1" Content="选择文件" Click="PickMedia_Click"/>
          </Grid>
          <Border Background="#100D17" BorderBrush="#292136" BorderThickness="1" CornerRadius="7" Padding="12" Margin="4,10,4,2">
           <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel><TextBlock Text="对象监看" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="默认只在 Omniphony Studio 显示，保持播放画面干净" Style="{StaticResource MutedText}" FontSize="10" Margin="0,3,0,0"/></StackPanel>
            <CheckBox Grid.Column="1" x:Name="ShowOverlayCheck" Content="在 mpv 画面叠加" VerticalAlignment="Center"/>
           </Grid>
          </Border>
         </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
         <StackPanel>
          <TextBlock Text="会话选项" Style="{StaticResource SectionTitle}"/>
          <WrapPanel><CheckBox x:Name="StartStudioCheck" Content="同时启动 Studio"/><CheckBox x:Name="OscCheck" Content="启用 OSC 监看"/><TextBlock Text="OSC 端口" Foreground="#AFA6BA" VerticalAlignment="Center" Margin="18,0,0,0"/><TextBox x:Name="OscPortBox" Width="86"/></WrapPanel>
          <TextBlock Text="附加 mpv 参数" Style="{StaticResource SectionTitle}" Margin="4,9,4,2"/><TextBox x:Name="ExtraArgsBox"/>
          <WrapPanel Margin="0,13,0,0"><Button Style="{StaticResource PrimaryButton}" Content="▶  启动空间音频播放" FontSize="14" Click="Launch_Click"/><Button Content="仅启动 Studio" Click="LaunchStudio_Click"/><Button Content="打开配置目录" Click="OpenConfigFolder_Click"/></WrapPanel>
         </StackPanel>
        </Border>
       </StackPanel>

       <StackPanel Grid.Column="2">
        <Border Style="{StaticResource CardStyle}">
         <StackPanel>
          <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="音频输出" Style="{StaticResource SectionTitle}"/><Border Grid.Column="1" Background="#11291E" CornerRadius="10" Padding="8,3"><TextBlock Text="ASIO / WASAPI" Foreground="#62E7A7" FontSize="9"/></Border></Grid>
          <TextBlock Text="输出设备" Foreground="#AFA6BA" FontSize="11" Margin="4,7,4,1"/>
          <ComboBox x:Name="AudioDeviceBox" DisplayMemberPath="DisplayName" SelectedValuePath="Id"/>
          <Button Content="↻  刷新音频设备" HorizontalAlignment="Stretch" Click="RefreshAudioDevices_Click"/>
          <Border Background="#10101B" BorderBrush="#2A2740" BorderThickness="1" CornerRadius="7" Padding="12" Margin="4,11,4,0">
           <StackPanel><TextBlock Text="DANTE 提示" Foreground="#B889FF" FontSize="10" FontWeight="Bold"/><TextBlock Text="使用 Dante Virtual Soundcard 时选择 [ASIO] 项。7.1.4 输出需要至少 12 路，建议 DVS 配置为 16×16 / 48 kHz。" Style="{StaticResource MutedText}" FontSize="10" Margin="0,5,0,0"/></StackPanel>
          </Border>
         </StackPanel>
        </Border>
        <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
         <StackPanel><TextBlock Text="信号链" Style="{StaticResource SectionTitle}"/>
          <Grid Margin="5,8"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/></Grid.ColumnDefinitions>
           <StackPanel HorizontalAlignment="Center"><Ellipse Width="34" Height="34" Fill="#1D2948" Stroke="#3C7FFF"/><TextBlock Text="MPV" FontSize="9" Margin="0,6,0,0" HorizontalAlignment="Center"/></StackPanel>
           <TextBlock Grid.Column="1" Text="→" Foreground="#8E59CE" FontSize="22" VerticalAlignment="Center" Margin="15,0"/>
           <StackPanel Grid.Column="2" HorizontalAlignment="Center"><Ellipse Width="34" Height="34" Fill="#382044" Stroke="#C04BFF"/><TextBlock Text="ORENDER" FontSize="9" Margin="0,6,0,0" HorizontalAlignment="Center"/></StackPanel>
          </Grid>
          <TextBlock Text="OSC 同步到 Studio · PCM 输出到所选音频设备" Style="{StaticResource MutedText}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
         </StackPanel>
        </Border>
       </StackPanel>
      </Grid>
     </ScrollViewer>
    </TabItem>

    <TabItem Header="组件与路径">
     <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,8">
      <Border Style="{StaticResource CardStyle}"><StackPanel>
       <Grid Margin="4,0,4,15"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="运行时组件" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="便携包会优先使用 runtime 目录；外部安装路径作为回退。" Style="{StaticResource MutedText}" FontSize="11" Margin="0,4,0,0"/></StackPanel><Button Grid.Column="1" Content="自动发现" Click="AutoDiscover_Click"/></Grid>
       <TextBlock Text="mpv-omniphony" Style="{StaticResource SectionTitle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="MpvPathBox"/><Button Grid.Column="1" Content="浏览" Tag="mpv" Click="BrowseExecutable_Click"/></Grid>
       <TextBlock Text="Omniphony Studio" Style="{StaticResource SectionTitle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="StudioPathBox"/><Button Grid.Column="1" Content="浏览" Tag="studio" Click="BrowseExecutable_Click"/></Grid>
       <TextBlock Text="orender CLI（诊断用途，mpv 播放不依赖独立进程）" Style="{StaticResource SectionTitle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="OrenderPathBox"/><Button Grid.Column="1" Content="浏览" Tag="orender" Click="BrowseExecutable_Click"/></Grid>
       <TextBlock Text="Harletty bridge" Style="{StaticResource SectionTitle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="BridgePathBox"/><Button Grid.Column="1" Content="浏览" Tag="bridge" Click="BrowseExecutable_Click"/></Grid>
       <TextBlock Text="共享 config.yaml" Style="{StaticResource SectionTitle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="ConfigPathBox"/><Button Grid.Column="1" Content="浏览" Tag="config" Click="BrowseExecutable_Click"/></Grid>
       <Button Style="{StaticResource PrimaryButton}" Content="保存设置并修复 bridge_path" HorizontalAlignment="Left" Margin="4,15,4,2" Click="SaveConfig_Click"/>
      </StackPanel></Border>
     </ScrollViewer>
    </TabItem>

    <TabItem Header="诊断日志">
     <Grid Margin="0,16,0,8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
      <Border Style="{StaticResource CardStyle}" Padding="14"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="系统自检" FontWeight="SemiBold"/><TextBlock Text="验证组件、ad_orender、Dante ASIO 与配置文件" Style="{StaticResource MutedText}" FontSize="10"/></StackPanel><WrapPanel Grid.Column="1"><Button Content="运行完整自检" Click="Diagnose_Click"/><Button Content="清空日志" Click="ClearLog_Click"/></WrapPanel></Grid></Border>
      <TextBox x:Name="LogBox" Grid.Row="1" Height="Auto" Margin="0,12,0,0" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas" FontSize="12" Background="#08070C"/>
     </Grid>
    </TabItem>
   </TabControl>

   <Grid Grid.Row="2"><TextBlock Text="OMNIPLAYER · MPV-OMNIPHONY + OMNIPHONY STUDIO + HARLETTY BRIDGE" Foreground="#665C72" FontSize="9" VerticalAlignment="Bottom"/><TextBlock Text="本地编排 · 不上传媒体与配置" Foreground="#665C72" FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Bottom"/></Grid>
  </Grid>
 </Grid>
</Window>
