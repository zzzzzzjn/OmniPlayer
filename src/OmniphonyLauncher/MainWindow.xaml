<Window x:Class="OmniphonyLauncher.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="OmniPlayer" Icon="assets/omniplayer.png" Width="1120" Height="800" MinWidth="940" MinHeight="680"
 Background="{StaticResource Surface}" Foreground="{StaticResource TextPrimary}" AllowDrop="True" Drop="Window_Drop">
 <Grid Background="{StaticResource Surface}" Margin="28,22,28,18">
  <Grid.RowDefinitions><RowDefinition Height="72"/><RowDefinition Height="*"/><RowDefinition Height="34"/></Grid.RowDefinitions>

  <Grid Grid.Row="0">
   <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
   <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
    <Button Width="48" Height="48" Padding="0" Margin="0,0,14,0" Background="#101015" BorderBrush="#2E2E37"
            Click="About_Click" ToolTip="{DynamicResource AboutTooltip}">
     <Border Width="38" Height="38" CornerRadius="8">
      <Border.Background>
       <ImageBrush ImageSource="assets/omniplayer.png" Stretch="UniformToFill" Viewbox="0,0,1,0.78" ViewboxUnits="RelativeToBoundingBox" RenderOptions.BitmapScalingMode="Fant"/>
      </Border.Background>
     </Border>
    </Button>
    <TextBlock Text="OmniPlayer" FontSize="23" FontWeight="SemiBold" VerticalAlignment="Center"/>
   </StackPanel>
   <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
    <Button x:Name="LanguageButton" Content="{DynamicResource LanguageButton}" Click="Language_Click" Padding="12,7" Margin="0,3,10,0"/>
    <Border Background="#101015" BorderBrush="#2E2E37" BorderThickness="1" CornerRadius="18" Padding="14,8" Margin="0,3,0,0">
     <StackPanel Orientation="Horizontal"><Ellipse Width="7" Height="7" Fill="{StaticResource Success}" Margin="0,0,8,0"/><TextBlock x:Name="OverallStatus" Text="{DynamicResource StatusChecking}" FontSize="12"/></StackPanel>
    </Border>
   </StackPanel>
  </Grid>

  <TabControl Grid.Row="1">
   <TabItem Header="{DynamicResource TabPlayback}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,8">
     <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="1.55*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
       <Border Style="{StaticResource CardStyle}"><StackPanel>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
         <StackPanel><TextBlock Text="{DynamicResource SourceTitle}" Style="{StaticResource SectionTitle}"/><TextBlock Text="{DynamicResource SourceDescription}" Style="{StaticResource MutedText}" FontSize="11" Margin="4,-4,0,8"/></StackPanel>
         <Border Grid.Column="1" Background="#1B1725" BorderBrush="#352A49" BorderThickness="1" CornerRadius="10" Padding="10,5" VerticalAlignment="Top"><TextBlock Text="{DynamicResource SourceBadge}" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="SemiBold"/></Border>
        </Grid>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="MediaPathBox"/><Button Grid.Column="1" Content="{DynamicResource ChooseFile}" Click="PickMedia_Click"/></Grid>
        <Border Background="#0B0B0F" BorderBrush="#24242C" BorderThickness="1" CornerRadius="12" Padding="13" Margin="4,10,4,2"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
         <StackPanel><TextBlock Text="{DynamicResource MonitoringTitle}" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{DynamicResource MonitoringDescription}" Style="{StaticResource MutedText}" FontSize="11" Margin="0,3,0,0"/></StackPanel>
         <CheckBox Grid.Column="1" x:Name="ShowOverlayCheck" Content="{DynamicResource ShowOverlay}" VerticalAlignment="Center"/>
        </Grid></Border>
       </StackPanel></Border>

       <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0"><StackPanel>
        <TextBlock Text="{DynamicResource SessionTitle}" Style="{StaticResource SectionTitle}"/>
        <WrapPanel><CheckBox x:Name="StartStudioCheck" Content="{DynamicResource StartStudio}"/><CheckBox x:Name="OscCheck" Content="{DynamicResource EnableOsc}"/><TextBlock Text="{DynamicResource OscPort}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="18,0,0,0"/><TextBox x:Name="OscPortBox" Width="86"/></WrapPanel>
        <TextBlock Text="{DynamicResource ExtraArguments}" Style="{StaticResource SectionTitle}" Margin="4,9,4,2"/><TextBox x:Name="ExtraArgsBox"/>
        <WrapPanel Margin="0,13,0,0"><Button Style="{StaticResource PrimaryButton}" Content="{DynamicResource LaunchPlayback}" FontSize="14" Click="Launch_Click"/><Button Content="{DynamicResource LaunchStudio}" Click="LaunchStudio_Click"/><Button Content="{DynamicResource OpenConfig}" Click="OpenConfigFolder_Click"/></WrapPanel>
       </StackPanel></Border>
      </StackPanel>

      <StackPanel Grid.Column="2">
       <Border Style="{StaticResource CardStyle}"><StackPanel>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{DynamicResource OutputTitle}" Style="{StaticResource SectionTitle}"/><TextBlock Grid.Column="1" Text="ASIO / WASAPI" Foreground="{StaticResource TextSecondary}" FontSize="10" VerticalAlignment="Center"/></Grid>
        <TextBlock Text="{DynamicResource OutputDevice}" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="4,7,4,1"/>
        <ComboBox x:Name="AudioDeviceBox" DisplayMemberPath="DisplayName" SelectedValuePath="Id"/>
        <Button Content="{DynamicResource RefreshDevices}" HorizontalAlignment="Stretch" Click="RefreshAudioDevices_Click"/>
        <Border Background="#0B0B0F" BorderBrush="#24242C" BorderThickness="1" CornerRadius="12" Padding="13" Margin="4,11,4,0"><StackPanel><TextBlock Text="{DynamicResource DanteTitle}" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold"/><TextBlock Text="{DynamicResource DanteDescription}" Style="{StaticResource MutedText}" FontSize="11" Margin="0,5,0,0"/></StackPanel></Border>
       </StackPanel></Border>
       <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0"><StackPanel>
        <TextBlock Text="{DynamicResource SignalTitle}" Style="{StaticResource SectionTitle}"/>
        <Grid Margin="5,8"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/></Grid.ColumnDefinitions>
         <StackPanel HorizontalAlignment="Center"><Ellipse Width="32" Height="32" Fill="#15171A" Stroke="#66666D"/><TextBlock Text="MPV" FontSize="10" Margin="0,6,0,0" HorizontalAlignment="Center"/></StackPanel>
         <TextBlock Grid.Column="1" Text="→" Foreground="{StaticResource Accent}" FontSize="21" VerticalAlignment="Center" Margin="15,0"/>
         <StackPanel Grid.Column="2" HorizontalAlignment="Center"><Ellipse Width="32" Height="32" Fill="#1A1720" Stroke="{StaticResource Accent}"/><TextBlock Text="ORENDER" FontSize="10" Margin="0,6,0,0" HorizontalAlignment="Center"/></StackPanel>
        </Grid>
        <TextBlock Text="{DynamicResource SignalDescription}" Style="{StaticResource MutedText}" FontSize="11" HorizontalAlignment="Center" Margin="0,5,0,0"/>
       </StackPanel></Border>
      </StackPanel>
     </Grid>
    </ScrollViewer>
   </TabItem>

   <TabItem Header="{DynamicResource TabComponents}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,8"><Border Style="{StaticResource CardStyle}"><StackPanel>
     <Grid Margin="4,0,4,15"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{DynamicResource RuntimeTitle}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="{DynamicResource RuntimeDescription}" Style="{StaticResource MutedText}" FontSize="11" Margin="0,4,0,0"/></StackPanel><Button Grid.Column="1" Content="{DynamicResource AutoDiscover}" Click="AutoDiscover_Click"/></Grid>
     <TextBlock Text="mpv-omniphony" Style="{StaticResource SectionTitle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="MpvPathBox"/><Button Grid.Column="1" Content="{DynamicResource Browse}" Tag="mpv" Click="BrowseExecutable_Click"/></Grid>
     <TextBlock Text="Omniphony Studio" Style="{StaticResource SectionTitle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="StudioPathBox"/><Button Grid.Column="1" Content="{DynamicResource Browse}" Tag="studio" Click="BrowseExecutable_Click"/></Grid>
     <TextBlock Text="{DynamicResource OrenderLabel}" Style="{StaticResource SectionTitle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="OrenderPathBox"/><Button Grid.Column="1" Content="{DynamicResource Browse}" Tag="orender" Click="BrowseExecutable_Click"/></Grid>
     <TextBlock Text="Harletty bridge" Style="{StaticResource SectionTitle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="BridgePathBox"/><Button Grid.Column="1" Content="{DynamicResource Browse}" Tag="bridge" Click="BrowseExecutable_Click"/></Grid>
     <TextBlock Text="{DynamicResource ConfigLabel}" Style="{StaticResource SectionTitle}"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="ConfigPathBox"/><Button Grid.Column="1" Content="{DynamicResource Browse}" Tag="config" Click="BrowseExecutable_Click"/></Grid>
     <Button Style="{StaticResource PrimaryButton}" Content="{DynamicResource SaveConfig}" HorizontalAlignment="Left" Margin="4,15,4,2" Click="SaveConfig_Click"/>
    </StackPanel></Border></ScrollViewer>
   </TabItem>

   <TabItem Header="{DynamicResource TabDiagnostics}">
    <Grid Margin="0,16,0,8"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions>
     <Border Style="{StaticResource CardStyle}" Padding="14"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{DynamicResource DiagnosticsTitle}" FontWeight="SemiBold"/><TextBlock Text="{DynamicResource DiagnosticsDescription}" Style="{StaticResource MutedText}" FontSize="11"/></StackPanel><WrapPanel Grid.Column="1"><Button Content="{DynamicResource RunDiagnostics}" Click="Diagnose_Click"/><Button Content="{DynamicResource ClearLog}" Click="ClearLog_Click"/></WrapPanel></Grid></Border>
     <TextBox x:Name="LogBox" Grid.Row="1" Height="Auto" Margin="0,12,0,0" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas" FontSize="12" Background="#050505"/>
    </Grid>
   </TabItem>
  </TabControl>

  <Grid Grid.Row="2">
   <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition/></Grid.ColumnDefinitions>
   <TextBlock Text="{DynamicResource FooterProduct}" Foreground="#777780" FontSize="10" VerticalAlignment="Bottom"/>
   <TextBlock Grid.Column="1" Text="{DynamicResource FooterDevelopers}" Foreground="#96969F" FontSize="10" VerticalAlignment="Bottom"/>
   <TextBlock Grid.Column="2" Text="{DynamicResource FooterLocal}" Foreground="#777780" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
  </Grid>
 </Grid>
</Window>
